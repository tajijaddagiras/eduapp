rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fungsi: apakah user sudah login?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Fungsi: apakah user mengakses dokumennya sendiri?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Fungsi: apakah user adalah Admin?
    // Menggunakan exists() untuk mencegah error saat dokumen belum ada
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =========================================================
    // 1. Collection 'users'
    // =========================================================
    match /users/{userId} {
      // User dapat membaca profil sendiri, Admin baca semua
      allow read: if isOwner(userId) || isAdmin();

      // PENTING: Izinkan user BARU membuat dokumen profil sendiri saat REGISTRASI
      // (create) - hanya perlu autentikasi & UID cocok, tidak perlu cek isAdmin
      allow create: if isOwner(userId);

      // Update & delete hanya pemilik atau admin
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    // =========================================================
    // 2. Collection 'materi'
    // =========================================================
    match /materi/{document=**} {
      // Semua user login bisa membaca materi
      allow read: if isAuthenticated();
      // Hanya admin yang bisa CRUD materi
      allow write: if isAdmin();
    }

    // =========================================================
    // 3. Collection 'soal' (Bank Soal & Simulasi)
    // =========================================================
    match /soal/{document=**} {
      // Semua user login bisa baca soal
      allow read: if isAuthenticated();
      // Hanya admin yang bisa CRUD soal
      allow write: if isAdmin();
    }

    // =========================================================
    // 4. Collection 'ueq_responses' (Hasil Kuesioner UEQ)
    // =========================================================
    match /ueq_responses/{document=**} {
      // Admin bisa membaca semua data UEQ untuk analitik
      allow read: if isAdmin();
      // User yang login hanya bisa SUBMIT (create) kuesioner
      allow create: if isAuthenticated();
      // Update & delete hanya admin
      allow update, delete: if isAdmin();
    }

    // =========================================================
    // 5. Collection 'progress' (Riwayat & Skor Belajar)
    // =========================================================
    match /progress/{progressId} {
      // User bisa baca progressnya sendiri, admin baca semua
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      // User bisa buat & update progress miliknya sendiri
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

  }
}
